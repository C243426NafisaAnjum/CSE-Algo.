#include #include #include using namespace std;

struct Edge { int u, v, w; };

bool cmp(Edge a, Edge b) { return a.w < b.w; }

vector parent, Rank;

int find(int x) { if (parent[x] == x) return x; return parent[x] = find(parent[x]); }

bool Union(int a, int b) { a = find(a); b = find(b);

if (a == b)
    return false;

if (Rank[a] < Rank[b])
    swap(a, b);

parent[b] = a;

if (Rank[a] == Rank[b])
    Rank[a]++;

return true;
}

int main() { int n, m; cin >> n >> m;

vector<Edge> edges(m);

for (int i = 0; i < m; i++) {
    cin >> edges[i].u >> edges[i].v >> edges[i].w;
}

sort(edges.begin(), edges.end(), cmp);

parent.resize(n + 1);
Rank.assign(n + 1, 0);

for (int i = 1; i <= n; i++)
    parent[i] = i;

long long cost = 0;

for (auto e : edges) {
    if (Union(e.u, e.v))
        cost += e.w;
}

cout << cost << endl;

return 0;
}
