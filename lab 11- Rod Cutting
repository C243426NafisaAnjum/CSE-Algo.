#include <iostream>  য
using namespace std;

int main()
{
    int n;
    cin >> n;

    int price[n + 1];

    for (int i = 1; i <= n; i++)
    {
        cin >> price[i];
    }

    int dp[n + 1];
  
    dp[0] = 0;

    for (int i = 1; i <= n; i++)
    {
        int maxVal = -1;

        for (int j = 1; j <= i; j++)
        {
            maxVal = max(maxVal, price[j] + dp[i - j]);
          
        }

        dp[i] = maxVal;

    }

    cout << "Maximum profit = " << dp[n];
    return 0;
}
