#include <stdio.h>

struct Activity
{
    int start;
    int finish;
};

void sort(struct Activity a[], int n)
{
    int i, j;
    struct Activity temp;

    for (i = 0; i < n - 1; i++)
    {
        for (j = i + 1; j < n; j++)
        {
            if (a[i].finish > a[j].finish)
            {
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
    }
}

void activitySelection(struct Activity a[], int n)
{
    int i;
    int last = 0;

    printf("Selected activities:\n");
    printf("(%d, %d)\n", a[last].start, a[last].finish);

    for (i = 1; i < n; i++)
    {
        if (a[i].start >= a[last].finish)
        {
            printf("(%d, %d)\n", a[i].start, a[i].finish);
            last = i;
        }
    }
}

int main()
{
    int n, i;

    scanf("%d", &n);

    struct Activity a[n];

    for (i = 0; i < n; i++)
        scanf("%d %d", &a[i].start, &a[i].finish);

    sort(a, n);

    activitySelection(a, n);

    return 0;
}
